# Database
DATABASE_URL=postgres://metadata_tool:password@localhost:5432/metadata_tool

# Server
HOST=0.0.0.0
PORT=8080
RUST_LOG=metadata_tool=debug,tower_http=debug

# Microsoft Entra ID (SSO)
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback

# JWT
# IMPORTANT: JWT_SECRET must be at least 32 characters and must not be the default value.
# Generate a secure secret with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY_HOURS=8

# Microsoft Graph API (Email)
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret
GRAPH_SENDER_EMAIL=metadata-tool@example.com

# AI Integration
AI_PRIMARY_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Settings Encryption
# IMPORTANT: In production (when ENTRA_TENANT_ID is a real UUID), this key MUST be set.
# Must be at least 32 characters and different from JWT_SECRET.
# Generate with: openssl rand -base64 48
# In development mode, this falls back to JWT_SECRET if not set.
SETTINGS_ENCRYPTION_KEY=

# Email Notifications
# Provider: "ses" (AWS SES), "graph" (Microsoft Graph API, not yet implemented), or "disabled"
NOTIFICATION_PROVIDER=disabled
SES_REGION=eu-west-1
SES_SENDER_EMAIL=noreply@example.com

# Frontend
FRONTEND_URL=http://localhost:5173
